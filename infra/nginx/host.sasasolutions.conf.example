# Host nginx example for SASA Forge v2.0 domains.
# Keep shared stack architecture with one stack per branch/environment:
# - production (main)   -> 127.0.0.1:8081
# - development (develop) -> 127.0.0.1:8082
#
# Domains:
# - sasasolutions.ca
# - www.sasasolutions.ca
# - 3dforge.sasasolutions.ca
# - www.3dforge.sasasolutions.ca -> 301 to https://3dforge.sasasolutions.ca
# - dev.sasasolutions.ca
# - dev.3dforge.sasasolutions.ca

# HTTP redirect for primary domains -> HTTPS
server {
  listen 80;
  listen [::]:80;
  server_name sasasolutions.ca www.sasasolutions.ca 3dforge.sasasolutions.ca;
  return 301 https://$host$request_uri;
}

# HTTPS app entrypoint for primary domains
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name sasasolutions.ca www.sasasolutions.ca 3dforge.sasasolutions.ca;

  # Certbot-managed certificates
  ssl_certificate /etc/letsencrypt/live/sasasolutions.ca/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/sasasolutions.ca/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  client_max_body_size 110m;

  # Shared Docker stack reverse proxy.
  # Internal routing there is:
  # - /      -> Next.js web
  # - /api/* -> FastAPI
  location / {
    proxy_pass http://127.0.0.1:8081;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
  }
}

# Dedicated redirect block (HTTP) for www.3dforge -> apex subdomain
server {
  listen 80;
  listen [::]:80;
  server_name www.3dforge.sasasolutions.ca;
  return 301 https://3dforge.sasasolutions.ca$request_uri;
}

# Dedicated redirect block (HTTPS) for www.3dforge -> apex subdomain
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name www.3dforge.sasasolutions.ca;

  # Certbot-managed certificates
  ssl_certificate /etc/letsencrypt/live/sasasolutions.ca/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/sasasolutions.ca/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  return 301 https://3dforge.sasasolutions.ca$request_uri;
}

# Dev 3dforge host -> develop stack
server {
  listen 80;
  listen [::]:80;
  server_name dev.3dforge.sasasolutions.ca;
  return 301 https://dev.3dforge.sasasolutions.ca$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name dev.3dforge.sasasolutions.ca;

  # Certbot-managed certificates
  ssl_certificate /etc/letsencrypt/live/sasasolutions.ca/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/sasasolutions.ca/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  client_max_body_size 110m;

  location / {
    proxy_pass http://127.0.0.1:8082;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
  }
}
